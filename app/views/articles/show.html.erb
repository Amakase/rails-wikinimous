<h1><%= @article[:title] %></h1>
<%= link_to edit_article_path do %>
  <i class="fa-solid fa-pencil"></i>
<% end %>
<%= link_to article_path, data: {turbo_method: :delete, turbo_confirm: "Are you sure?"} do %>
  <i class="fa-solid fa-trash-can"></i>
<% end %>
<hr />
<p><%= @article[:content] %></p>
